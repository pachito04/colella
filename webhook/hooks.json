[
  {
    "id": "deploy-colella",
    "execute-command": "/opt/colella/deploy.sh",
    "command-working-directory": "/opt/colella",
    "response-message": "Deploy iniciado",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "REEMPLAZAR_CON_TU_SECRET",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    }
  }
]
